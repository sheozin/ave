# ── Supabase project credentials ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# Your Supabase project URL (found in Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to embed in client HTML
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — used ONLY by Edge Functions (server-side)
# Keep this secret; grants full database access
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend Email API ─────────────────────────────────────────────────────────
# Used for sending founder welcome emails and sequences
# Get your API key from: https://resend.com/api-keys

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=sheriff@cuedeck.io
FROM_NAME=Sheriff from CueDeck

# ── Optional: E2E live-DB tests ────────────────────────────────────────────────
# Only needed when running: TEST_EMAIL=... TEST_PASSWORD=... npm run test:e2e
# Point TEST_SESSION_ID at a PLANNED session in a dedicated test event.

TEST_EMAIL=operator@example.com
TEST_PASSWORD=your-test-password
TEST_SESSION_ID=00000000-0000-0000-0000-000000000001
